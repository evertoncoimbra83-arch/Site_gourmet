{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node", /* Alterado para 'node' para melhor suporte ao process.env no backend */
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "allowImportingTsExtensions": true,
    
    /* ✅ TIPAGEM GLOBAL: Garante reconhecimento do Node, Vite e Express */
    "types": [
      "node", 
      "vite/client", 
      "express",
      "express-fileupload"
    ],
    
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"],
      "@server/*": ["./server/*"]
    },
    "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo"
  },
  "include": [
    "next-env.d.ts",
    "client/src/**/*", 
    "shared/**/*", 
    "server/**/*", 
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules", 
    "build", 
    "dist", 
    "**/*.test.ts"
  ]
}